<div class="realmsforge-container" style="padding: 10px; font-family: var(--font-primary);">
    <p style="color: #555; font-style: italic; margin-top: 0;">
        Gérez les factions, royaumes et menaces. Propagez leur influence sur la carte.
    </p>

    <div style="margin-bottom: 15px;">
        <button id="rf-add-faction" style="background: #27ae60; color: white; border: none; font-weight: bold;">
            <i class="fas fa-plus"></i> Fonder une nouvelle Faction
        </button>
    </div>

    <hr style="border-top: 1px dashed #ccc;">

    <div id="rf-factions-list" style="max-height: 400px; overflow-y: auto; padding-right: 5px;">
        {{#each factions}}
        <div class="rf-faction-card" data-id="{{this.id}}" style="background: rgba(0,0,0,0.05); border: 1px solid #bdc3c7; border-radius: 5px; padding: 10px; margin-bottom: 15px;">
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <input type="text" class="rf-edit-field" data-field="name" value="{{this.name}}" placeholder="Nom de la Faction" style="font-weight: bold; font-size: 1.2em; border: 1px solid transparent; background: transparent; width: 60%;" title="Modifier le nom">
                <a class="rf-delete-faction" style="color: #c0392b; cursor: pointer;" title="Détruire la Faction"><i class="fas fa-trash"></i></a>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                <div>
                    <label style="font-size: 0.8em; color: #7f8c8d; font-weight: bold;">Type</label>
                    <input type="text" class="rf-edit-field" data-field="type" value="{{this.type}}" placeholder="ex: Criminel, Royaume..." style="width: 100%;">
                </div>
                <div>
                    <label style="font-size: 0.8em; color: #7f8c8d; font-weight: bold;">Rayon d'Influence</label>
                    <select class="rf-edit-field" data-field="level" style="width: 100%;">
                        <option value="1" {{#if (eq this.level "1")}}selected{{/if}}>Niveau 1 (La case ciblée)</option>
                        <option value="2" {{#if (eq this.level "2")}}selected{{/if}}>Niveau 2 (1 case autour)</option>
                        <option value="3" {{#if (eq this.level "3")}}selected{{/if}}>Niveau 3 (2 cases autour)</option>
                        <option value="4" {{#if (eq this.level "4")}}selected{{/if}}>Niveau 4 (3 cases autour)</option>
                        <option value="5" {{#if (eq this.level "5")}}selected{{/if}}>Niveau 5 (Royaume : 4 cases)</option>
                    </select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
                <div>
                    <label style="font-size: 0.8em; color: #7f8c8d; font-weight: bold;">Aura (Vibe tags séparés par virgules)</label>
                    <input type="text" class="rf-edit-field" data-field="vibes" value="{{this.vibes}}" placeholder="ex: corrompu, magie-forte" style="width: 100%; border-bottom: 2px solid #8e44ad;">
                </div>
                <div>
                    <label style="font-size: 0.8em; color: #7f8c8d; font-weight: bold;">Capitale (ID de la case)</label>
                    <input type="text" class="rf-edit-field" data-field="hexId" value="{{this.hexId}}" placeholder="ex: hex_5_12" style="width: 100%;">
                </div>
            </div>

            <button class="rf-propagate-btn" style="background: #2980b9; color: white; border: none; margin-top: 5px;">
                <i class="fas fa-broadcast-tower"></i> Propager l'Influence sur la carte
            </button>
        </div>
        {{else}}
        <p style="text-align: center; color: #95a5a6; padding: 20px;">Aucune faction n'a encore été fondée. Créez votre première puissance !</p>
        {{/each}}
    </div>

    <hr style="border-top: 1px solid #e74c3c; margin-top: 20px;">
    
    <div style="background: rgba(192, 57, 43, 0.1); border: 1px solid #e74c3c; border-radius: 5px; padding: 10px;">
        <h3 style="color: #c0392b; margin-top: 0; font-size: 1.1em;"><i class="fas fa-radiation"></i> Cataclysme Régional</h3>
        <p style="font-size: 0.85em; color: #555; margin-bottom: 10px;">Détruit toutes les colonies présentes sur la carte dans la région sélectionnée. (Les journaux sont conservés).</p>
        
        <div style="display: flex; gap: 10px;">
            <select id="rf-purge-region" style="flex-grow: 1; padding: 5px;">
                <option value="none" selected disabled>Choisir une région à purger...</option>
                {{#each regions}}
                <option value="{{this}}">{{this}}</option>
                {{/each}}
            </select>
            <button id="rf-purge-btn" style="background: #c0392b; color: white; border: none; font-weight: bold; width: 40px; border-radius: 4px; cursor: pointer;" title="Déclencher la Purge">
                <i class="fas fa-skull"></i>
            </button>
        </div>
    </div>
</div>