<div class="hf-hud-container" style="font-family: var(--font-primary); padding: 10px;">
    
    <div style="display: flex; gap: 5px; margin-bottom: 15px;">
        <button id="hf-mode-edit" class="hf-mode-btn active" style="flex: 1; background: #2980b9; color: white; border: none; border-radius: 4px; padding: 8px; font-weight: bold;" title="Mode Édition (Clic = Ouvrir la case)"><i class="fas fa-mouse-pointer"></i> Éditer</button>
        <button id="hf-mode-brush" class="hf-mode-btn" style="flex: 1; background: #34495e; color: white; border: none; border-radius: 4px; padding: 8px; font-weight: bold;" title="Mode Pinceau (Maintenir le clic pour peindre)"><i class="fas fa-paint-brush"></i> Peindre</button>
    </div>

    <div id="hf-brush-options" style="display: none; flex-direction: column; gap: 12px; background: rgba(0,0,0,0.05); padding: 10px; border-radius: 5px; border: 1px solid #bdc3c7;">
        
        <div>
            <label style="font-size: 0.85em; color: #555; font-weight: bold;"><i class="fas fa-globe"></i> Région à peindre</label>
            <select id="hf-brush-region" style="width: 100%; padding: 4px;">
                <option value="">-- Ne pas modifier --</option>
                <option value="none">❌ Effacer la région (Gomme)</option>
                {{#each regions}}
                <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
            </select>
        </div>

        <div>
            <label style="font-size: 0.85em; color: #555; font-weight: bold;"><i class="fas fa-tree"></i> Biome à peindre</label>
            <select id="hf-brush-biome" style="width: 100%; padding: 4px;">
                <option value="">-- Ne pas modifier --</option>
                <option value="none">❌ Effacer le biome (Gomme)</option>
                {{#each biomes}}
                <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
            </select>
        </div>
        <div>
            <label style="font-size: 0.85em; color: #555; font-weight: bold;"><i class="fas fa-road"></i> Trait à peindre</label>
            <select id="hf-brush-trait" style="width: 100%; padding: 4px;">
                <option value="">-- Ne pas modifier --</option>
                <option value="none">❌ Effacer le trait (Gomme)</option>
                <option value="route_pavee">Route Impériale / Pavée</option>
                <option value="chemin_terre">Chemin de terre / Sentier</option>
                <option value="riviere">Cours d'eau / Rivière</option>
                <option value="lac">Lac / Étang</option>
                <option value="faille">Faille / Gouffre</option>
                <option value="grotte">Entrée de Grotte</option>
            </select>
        </div>
        <p style="font-size: 0.8em; color: #e67e22; font-style: italic; margin: 0; text-align: center;"><i class="fas fa-info-circle"></i> Maintenez le clic gauche sur la carte et glissez.</p>
    </div>
</div>